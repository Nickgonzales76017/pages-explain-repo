#!/usr/bin/env bash
# ─── Bonfyre Pages App Hook ──────────────────────────────────────────────────
set -euo pipefail

BONFYRE_BIN="${BONFYRE_BIN:-$HOME/.local/bin}"
export PATH="$BONFYRE_BIN:$PATH"

log() { printf "\033[0;33m[bonfyre]\033[0m %s\n" "$1"; }
err() { printf "\033[0;31m[bonfyre]\033[0m %s\n" "$1" >&2; }

require_bin() {
  for b in "$@"; do
    command -v "$b" >/dev/null 2>&1 || { err "Missing: $b (run 'make install' in bonfyre-oss)"; return 1; }
  done
}

BINS=(bonfyre-ingest bonfyre-transcribe bonfyre-brief bonfyre-tag bonfyre-embed bonfyre-vec bonfyre-emit bonfyre-render)
require_bin "${BINS[@]}" || exit 0

# Detect source code changes
SRC_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD -- input/source/ 2>/dev/null || true)
# Detect walkthrough recordings
WALK_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD -- input/walkthroughs/ 2>/dev/null || true)

[ -z "$SRC_CHANGED" ] && [ -z "$WALK_CHANGED" ] && exit 0

# Process source files
if [ -n "$SRC_CHANGED" ]; then
  log "Ingesting $(echo "$SRC_CHANGED" | wc -l | tr -d ' ') source file(s)…"
  for f in $SRC_CHANGED; do
    [ -f "$f" ] || continue
    base=$(basename "$f" | sed 's/\.[^.]*$//')
    bonfyre-ingest "$f" --out "artifacts/${base}.ingest.json"
    bonfyre-tag "artifacts/${base}.ingest.json" --out "artifacts/${base}.tags.json"
    bonfyre-embed "artifacts/${base}.tags.json" --out "artifacts/${base}.embed.json"
    bonfyre-vec "artifacts/${base}.embed.json" --insert-db "artifacts/repo.db"
  done
fi

# Process walkthrough recordings
if [ -n "$WALK_CHANGED" ]; then
  log "Processing $(echo "$WALK_CHANGED" | wc -l | tr -d ' ') walkthrough(s)…"
  for f in $WALK_CHANGED; do
    [ -f "$f" ] || continue
    base=$(basename "$f" | sed 's/\.[^.]*$//')
    bonfyre-transcribe "$f" --out "artifacts/${base}.transcript.json"
    bonfyre-brief "artifacts/${base}.transcript.json" --out "artifacts/${base}.brief.json"
    bonfyre-tag "artifacts/${base}.brief.json" --out "artifacts/${base}.tags.json"
    bonfyre-embed "artifacts/${base}.tags.json" --out "artifacts/${base}.embed.json"
    bonfyre-vec "artifacts/${base}.embed.json" --insert-db "artifacts/repo.db"
  done
fi

log "Generating onboarding guide…"
bonfyre-render artifacts/ --template guide --out site/
bonfyre-emit artifacts/ --out site/ --format html
log "Guide updated. Source + walkthroughs indexed."
